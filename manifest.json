{
  "manifest_version": 3,
  "name": "Blackhole Break",
  "version": "1.1.0",
  "description": "An interactive, non-blocking 20min/30sec cosmic eye tracker.",
  "action": {
    "default_title": "Blackhole Break",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["alarms", "idle", "storage", "tabs", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}